{
  "headers": [
    {
      "source": "assets/**/*.@(js|css|woff|woff2|svg|png|jpg|jpeg|webp|avif|gif|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "**/*.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
